{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Expo Web",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start", "--web", "--port", "19006", "-c"],
      "port": 19006
    },
    {
      "name": "Expo Metro (Android / iOS)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start", "--port", "8081"],
      "port": 8081
    },
    {
      "name": "TypeScript Watch",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["tsc", "--noEmit", "--watch", "--pretty"],
      "port": 6789
    },
    {
      "name": "Jest (watch)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["jest", "--watchAll", "--no-coverage"],
      "port": 9229
    }
  ]
}
